# Large files and results (too big for GitHub)
*.png
*.pdf
*.jpg
*.jpeg
*.gif
*.svg

# Results directories (but keep cognition_results)
*_results/
*_output/
*_figures/
*_analysis/
!cognition_results/

# Temporary files
*.tmp
*.temp
*.log
*.cache

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Large data files
*.csv
*.json
*.h5
*.hdf5
*.pkl
*.pickle

# Keep only essential code and small config files
!README.md
!*.py
!*.md
!*.yml
!*.yaml
!*.txt
!requirements.txt
!setup.py
